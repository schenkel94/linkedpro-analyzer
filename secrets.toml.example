# Este é um EXEMPLO de como configurar os secrets no Streamlit Cloud
# NÃO commite este arquivo com dados reais!

# INSTRUÇÕES:
# 1. No Streamlit Cloud, vá em Settings → Secrets
# 2. Cole o conteúdo abaixo com seus dados reais
# 3. Substitua os valores de exemplo pelos seus

# ===== Google Service Account (Opcional - para salvar leads) =====
[gcp_service_account]
type = "service_account"
project_id = "seu-projeto-123456"
private_key_id = "abc123def456..."
private_key = "-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBg...\n(sua chave completa aqui)\n-----END PRIVATE KEY-----\n"
client_email = "linkedpro-sheets@seu-projeto.iam.gserviceaccount.com"
client_id = "123456789012345678901"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/seu-email%40seu-projeto.iam.gserviceaccount.com"

# ===== URL da Planilha Google Sheets (Opcional) =====
google_sheet_url = "https://docs.google.com/spreadsheets/d/1ABC...XYZ/edit"

# ===== DICAS IMPORTANTES =====
# 
# 1. A private_key DEVE ter \n no final de cada linha
#    Correto: "-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"
#    Errado:  "-----BEGIN PRIVATE KEY-----MIIEv...-----END PRIVATE KEY-----"
#
# 2. Não precisa de aspas duplas no arquivo de secrets do Streamlit
#
# 3. Para testar localmente, crie um arquivo .streamlit/secrets.toml
#    (Ele está no .gitignore e NÃO será commitado)
#
# 4. Certifique-se de compartilhar a planilha com o client_email
#
# 5. Se não quiser configurar Google Sheets agora, tudo bem!
#    O app funciona sem ele, só não vai salvar os leads.
